#!/bin/sh
# Bloquea AGREGAR node_modules o dist al repo (permitir borrarlos del historial)

blocked=$(git diff --cached --name-only --diff-filter=AM | grep -E '^(node_modules/|dist/)')

if [ -n "$blocked" ]; then
  echo ""
  echo "ERROR: No puedes agregar archivos en node_modules/ ni dist/"
  echo "Usa: npm install  y  npm run build  (localmente, no en git)."
  echo ""
  exit 1
fi

if command -v node >/dev/null 2>&1; then
  node scripts/ensure-utf8.mjs
  if [ $? -ne 0 ]; then
    echo ""
    echo "Corrige con: npm run fix:encoding"
    echo ""
    exit 1
  fi
fi

exit 0
